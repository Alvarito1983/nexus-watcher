# ═══════════════════════════════════════════════
# NEXUS Watcher — Environment variables
# ═══════════════════════════════════════════════

# Shared API key (same as nexus-core)
NEXUS_API_KEY=nexus-dev-local

# Integration with NEXUS (optional)
NEXUS_URL=http://localhost:3001

# Integration with NEXUS Notify (optional)
NOTIFY_URL=

# Scan interval in seconds (default: 3600 = 1h)
SCAN_INTERVAL=3600

# GHCR token if you use private ghcr.io images (optional)
GHCR_TOKEN=

# ─── AUTH ──────────────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=admin
